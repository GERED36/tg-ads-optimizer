{
  "buildCommand": "cd dashboard && npm run build",
  "outputDirectory": "dashboard/dist",
  "installCommand": "npm install && cd dashboard && npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
