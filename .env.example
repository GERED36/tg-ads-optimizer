# Database (SQLite — local file, no server needed)
DATABASE_URL="file:./dev.db"

# Redis (optional for caching, skip for local dev)
REDIS_URL="redis://localhost:6379"

# Telegram Ads API
TELEGRAM_ADS_API_TOKEN="your-telegram-ads-api-token"
TELEGRAM_ADS_API_BASE_URL="https://api.telegram.org/ads/v1"

# Agent Configuration
OPTIMIZATION_INTERVAL_MS=900000
CPC_TARGET=0.5
CPO_TARGET=10.0
MIN_CTR_PERCENT=0.5
PID_KP=0.1
PID_KI=0.01
PID_KD=0.05

# Server
PORT=3001
DASHBOARD_URL=http://localhost:5173
